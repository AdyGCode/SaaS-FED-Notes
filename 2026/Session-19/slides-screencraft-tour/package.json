{
  "name": "ScreenCraft Tour",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "rm -Rf node_modules pnpm-lock.yaml package.lock && pnpm install",
    "build": "slidev build",
    "dev": "slidev --open",
    "export": "slidev export",
    "show": "slidev --remote SecretOne --port 8080 --open --force"
  },
  "dependencies": {
    "@iconify-json/fa-brands": "^1.2.2",
    "@iconify-json/fa-regular": "^1.2.2",
    "@iconify-json/fa-solid": "^1.2.2",
    "@slidev/types": "^0.50.0-beta.5",
    "@unocss/preset-icons": "^66.6.8",
    "codemirror-theme-vars": "^0.1.1",
    "prism-theme-vars": "^0.2.4",
    "slidev-addon-sync": "^0.1.0",
    "slidev-component-poll": "^3.0.0",
    "slidev-theme-nmt": "^0.9.10",
    "theme-vitesse": "^0.6.2"
  },
  "devDependencies": {
    "@slidev/cli": "^0.50.0-beta.5",
    "@types/node": "^18.13.0"
  },
  "//": "Learn more: https://sli.dev/themes/write-a-theme.html",
  "slidev": {
    "colorSchema": "both",
    "defaults": {
      "fonts": {
        "provider": "coollabs",
        "mono": "Fira Code,consolas",
        "serif": "Roboto Serif,Georgia",
        "sans": "Avenir Next.Arial",
        "local": "Avenir Next,Arial",
        "italic": false
      },
      "transition": "fade",
      "aspectRatio": "16/10",
      "addons": [
        "slidev-component-poll"
      ]
    }
  },
  "author": "Adrian Gould <ady.g.coder@gmail.com>",
  "funding": "https://github.com/sponsors/adygcode",
  "bugs": "https://github.com/adygcode/slidev-theme-nmt/issues"
}
