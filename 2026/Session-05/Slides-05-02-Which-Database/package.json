    "@napi-rs/wasm-runtime": "^1.1.3",
    "@slidev/cli": "^52.14.2",
    "@slidev/client": "^52.14.2",
    "@slidev/types": "^52.14.2",
    "@unocss/preset-icons": "^66.6.8",
    "dompurify": "^3.3.3",
    "emnapi": "^1.9.2",
    "nuxt": "^4.4.2",
    "shiki": "^4.0.2",
    "shiki-magic-move": "^1.3.0",
    "slidev-addon-sync": "^0.1.0",
    "slidev-component-poll": "^3.0.0",
    "slidev-theme-nmt": "^0.9.2",
    "unplugin-vue-markdown": "^30.0.0",
